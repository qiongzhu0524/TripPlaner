# ===== LLM Providers =====
DEFAULT_LLM_PROVIDER=openai

# OpenAI
LLM_OPENAI__API_KEY=sk-your-openai-key
LLM_OPENAI__MODEL=gpt-4o
LLM_OPENAI__MAX_TOKENS=4096
LLM_OPENAI__TEMPERATURE=0.7

# Anthropic
LLM_ANTHROPIC__API_KEY=sk-ant-your-anthropic-key
LLM_ANTHROPIC__MODEL=claude-sonnet-4-20250514

# DeepSeek
LLM_DEEPSEEK__API_KEY=sk-your-deepseek-key
LLM_DEEPSEEK__BASE_URL=https://api.deepseek.com
LLM_DEEPSEEK__MODEL=deepseek-chat

# ===== Amap (高德地图) =====
AMAP__API_KEY=your_amap_api_key

# ===== Database =====
DATABASE__DSN=postgresql+asyncpg://tripuser:tripsecret@localhost:5432/tripplaner
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20

# ===== Memory =====
MEMORY__SHORT_TERM_MAX_TOKENS=4000
MEMORY__SHORT_TERM_SUMMARY_MODEL=gpt-4o-mini
MEMORY__LONG_TERM_ENABLED=true

# ===== General =====
DEBUG=false
LOG_LEVEL=INFO
